  text-align:center; color:var(--pglow);
  font-size:14px; font-weight:700; letter-spacing:.5px;
  margin-bottom:14px; word-break:break-all;
}

/* ===== FOOTER ===== */
.footer { flex-shrink:0; margin-top:28px; text-align:center; font-size:10px; color:rgba(120,80,180,.3); letter-spacing:2px; }
</style>
