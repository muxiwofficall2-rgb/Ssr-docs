<style>
:root {
  --bg:      #000;
  --bg2:     #080010;
  --card:    #0E0020;
  --cardbor: #3B1060;
  --cardhov: #1A0038;
  --purple:  #7B2FBE;
  --pglow:   #BF7FFF;
  --white:   #F0E8FF;
  --grey:    #9B7FBF;
  --accent:  #A855F7;
}
* { margin:0; padding:0; box-sizing:border-box; }
html, body {
  width:100%; height:100%;
  background:#000;
  color:var(--white);
  font-family:'Raleway',sans-serif;
  overflow:hidden;
}

/* ===== BG ===== */
.bg {
  position:fixed; inset:0; z-index:0;
  background:#000;
  pointer-events:none; overflow:hidden;
}
.bg::before {
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(ellipse 70% 50% at 30% 20%, rgba(80,0,160,0.28) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 75% 75%, rgba(60,0,120,0.2) 0%, transparent 55%);
}
.particles { position:absolute; inset:0; }
.p { position:absolute; border-radius:50%; }
.pu { animation:goUp   linear infinite; }
.pd { animation:goDown linear infinite; }

.p1  { width:2px;height:2px;background:#A855F7;left:7%;  bottom:0;  opacity:.6; animation-duration:11s;animation-delay:0s;   }
.p2  { width:2px;height:2px;background:#BF7FFF;left:16%; bottom:0;  opacity:.4; animation-duration:15s;animation-delay:2s;   }
.p3  { width:3px;height:3px;background:#fff;   left:26%; bottom:0;  opacity:.25;animation-duration:9s; animation-delay:1s;   }
.p4  { width:2px;height:2px;background:#A855F7;left:37%; bottom:0;  opacity:.5; animation-duration:13s;animation-delay:4s;   }
.p5  { width:2px;height:2px;background:#7B2FBE;left:48%; bottom:0;  opacity:.45;animation-duration:17s;animation-delay:0.5s; }
.p6  { width:3px;height:3px;background:#BF7FFF;left:60%; bottom:0;  opacity:.35;animation-duration:10s;animation-delay:3s;   }
.p7  { width:2px;height:2px;background:#fff;   left:71%; bottom:0;  opacity:.2; animation-duration:14s;animation-delay:5.5s; }
.p8  { width:2px;height:2px;background:#A855F7;left:82%; bottom:0;  opacity:.5; animation-duration:12s;animation-delay:1.5s; }
.p9  { width:2px;height:2px;background:#7B2FBE;left:91%; bottom:0;  opacity:.4; animation-duration:16s;animation-delay:4.5s; }
.p10 { width:3px;height:3px;background:#BF7FFF;left:4%;  bottom:0;  opacity:.3; animation-duration:18s;animation-delay:7s;   }
.p11 { width:2px;height:2px;background:#A855F7;left:22%; top:0;     opacity:.3; animation-duration:19s;animation-delay:3s;   }
.p12 { width:2px;height:2px;background:#fff;   left:44%; top:0;     opacity:.2; animation-duration:13s;animation-delay:8s;   }
.p13 { width:3px;height:3px;background:#BF7FFF;left:66%; top:0;     opacity:.3; animation-duration:21s;animation-delay:2s;   }
.p14 { width:2px;height:2px;background:#A855F7;left:79%; top:0;     opacity:.25;animation-duration:15s;animation-delay:6s;   }
.p15 { width:2px;height:2px;background:#7B2FBE;left:55%; top:0;     opacity:.2; animation-duration:17s;animation-delay:5s;   }

@keyframes goUp   { 0%{transform:translateY(0);opacity:0} 8%{opacity:.5} 92%{opacity:.3} 100%{transform:translateY(-100vh);opacity:0} }
@keyframes goDown { 0%{transform:translateY(0);opacity:0} 8%{opacity:.4} 92%{opacity:.2} 100%{transform:translateY(100vh);opacity:0}  }

/* ===== APP ===== */
#app { position:fixed; inset:0; z-index:1; overflow:hidden; }

.screen {
  position:absolute; inset:0;
  display:flex; flex-direction:column; align-items:center;
  overflow-y:auto; overflow-x:hidden;
  padding:0 16px 50px;
  transition:transform .38s cubic-bezier(.4,0,.2,1), opacity .38s ease;
}
#home { transform:translateX(0); opacity:1; }
#home.pushed { transform:translateX(-100%); opacity:0; }
.inner { transform:translateX(100%); opacity:0; pointer-events:none; }
.inner.active { transform:translateX(0); opacity:1; pointer-events:all; }

/* ===== TOPBAR ===== */
.topbar {
  width:100%; max-width:460px;
  display:flex; align-items:center; justify-content:space-between;
  padding:16px 0 10px; flex-shrink:0;
}
.back-btn {
  display:flex; align-items:center; gap:6px;
  padding:8px 14px 8px 10px;
  border-radius:22px;
  border:1.5px solid var(--cardbor);
  background:var(--card);
  color:var(--white);
  font-family:'Raleway',sans-serif; font-size:13px; font-weight:700;
  cursor:pointer; letter-spacing:.3px;
  transition:background .2s,border-color .2s,box-shadow .2s;
}
.back-btn:hover {
  background:var(--cardhov); border-color:var(--pglow);
  box-shadow:0 0 12px rgba(168,85,247,.35);
}
.lang-row { display:flex; gap:7px; }
.lang-btn {
  display:flex; align-items:center; gap:5px;
  padding:7px 12px; border-radius:22px;
  border:1.5px solid var(--cardbor);
  background:var(--card); color:var(--white);
  font-family:'Raleway',sans-serif; font-size:12px; font-weight:700;
  cursor:pointer; transition:all .2s;
}
.lang-btn.active,.lang-btn:hover {
  background:var(--cardhov); border-color:var(--pglow);
  box-shadow:0 0 10px rgba(168,85,247,.4);
}

/* ===== LOGO ===== */
.logo-wrap {
  text-align:center; margin:16px 0 6px;
  animation:fadeDown .8s ease both;
  width:100%; max-width:460px; flex-shrink:0;
}
@keyframes fadeDown { from{opacity:0;transform:translateY(-22px)} to{opacity:1;transform:translateY(0)} }
.logo-eyebrow { font-size:10px; letter-spacing:5px; color:var(--pglow); text-transform:uppercase; margin-bottom:6px; opacity:.75; }
.logo-name {
  font-family:'Playfair Display',serif;
  font-size:clamp(28px,8vw,48px); font-weight:900; line-height:1.05;
  background:linear-gradient(130deg,#fff 0%,#D8A8FF 45%,#A855F7 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.logo-tag { font-size:11px; letter-spacing:3px; color:var(--grey); text-transform:uppercase; margin-top:5px; }
.logo-rule {
  width:70px; height:1.5px; margin:10px auto 0;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);
  animation:ruleAnim 3s ease-in-out infinite;
}
@keyframes ruleAnim { 0%,100%{width:50px;opacity:.4} 50%{width:130px;opacity:1} }

.sec-label { font-size:10px; letter-spacing:5px; color:var(--pglow); text-transform:uppercase; opacity:.7; margin:22px 0 12px; flex-shrink:0; }

/* ===== HOME CARDS ===== */
.home-list {
  width:100%; max-width:460px;
  display:flex; flex-direction:column; gap:10px;
  animation:fadeUp .8s ease .2s both; flex-shrink:0;
}
@keyframes fadeUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }

.home-card {
  display:flex; align-items:center; gap:14px;
  padding:15px 16px; border-radius:14px;
  border:1.5px solid var(--cardbor);
  background:var(--card);
  cursor:pointer; text-decoration:none; color:var(--white);
  transition:background .22s,border-color .22s,transform .18s,box-shadow .22s;
}
.home-card:hover {
  background:var(--cardhov); border-color:var(--pglow);
  box-shadow:0 4px 24px rgba(80,0,160,.5),0 0 16px rgba(168,85,247,.25);
  transform:translateY(-2px);
}
.home-card:active { transform:scale(.97); }

.hc-icon {
  width:44px; height:44px; border-radius:12px;
  background:var(--bg2); border:1.5px solid var(--cardbor);
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.hc-icon svg { width:22px; height:22px; }
.hc-info { flex:1; min-width:0; }
.hc-title { font-family:'Playfair Display',serif; font-size:15px; font-weight:700; color:var(--white); }
.hc-sub { font-size:12px; color:var(--grey); margin-top:2px; }
.hc-chev { opacity:.3; flex-shrink:0; transition:opacity .2s,transform .2s; }
.home-card:hover .hc-chev { opacity:.8; transform:translateX(3px); }

/* ===== INNER ===== */
.inner-wrap { width:100%; max-width:460px; flex:1; display:flex; flex-direction:column; }
.screen-head { text-align:center; margin:10px 0 20px; }
.screen-title { font-family:'Playfair Display',serif; font-size:22px; font-weight:700; color:var(--white); }
.screen-sub { font-size:11px; letter-spacing:3px; color:var(--grey); text-transform:uppercase; margin-top:4px; }

.item-list { display:flex; flex-direction:column; gap:10px; }

.item-btn {
  display:flex; align-items:center; gap:14px;
  padding:16px 16px; border-radius:14px;
  border:1.5px solid var(--cardbor);
  background:var(--card); color:var(--white); text-decoration:none;
  font-size:15px; font-weight:600; cursor:pointer;
  transition:background .22s,border-color .22s,transform .18s,box-shadow .22s;
}
.item-btn:hover {
  background:var(--cardhov); border-color:var(--pglow);
  box-shadow:0 4px 20px rgba(80,0,160,.5),0 0 14px rgba(168,85,247,.2);
  transform:translateX(5px);
}
.item-btn:active { transform:scale(.97); }

.ib-icon {
  width:44px; height:44px; border-radius:12px;
  background:var(--bg2); border:1.5px solid var(--cardbor);
  display:flex; align-items:center; justify-content:center;
  font-size:20px; flex-shrink:0;
}
.ib-info { flex:1; min-width:0; }
.ib-name { font-size:15px; font-weight:700; color:var(--white); }
.ib-handle { font-size:12px; color:var(--pglow); margin-top:3px; }
.ib-num {
  font-size:10px; font-weight:700;
  background:var(--bg2); border:1px solid var(--cardbor);
  color:var(--grey); padding:3px 9px; border-radius:20px; flex-shrink:0;
}
.ib-chev { opacity:.3; flex-shrink:0; transition:opacity .2s,transform .2s; }
.item-btn:hover .ib-chev { opacity:.7; transform:translateX(3px); }

/* ===== ADDRESS ===== */
.addr-card {
  background:var(--card); border:1.5px solid var(--cardbor);
  border-radius:14px; padding:22px 18px;
  text-align:center; margin-bottom:12px;
}
.addr-line { font-family:'Playfair Display',serif; font-size:20px; font-weight:700; color:var(--white); line-height:1.7; }
.dom-row {
  display:inline-flex; align-items:center; gap:8px;
  margin-top:14px; padding:10px 18px;
  border-radius:10px; background:var(--bg2); border:1.5px solid var(--cardbor);
}
.dot { width:9px; height:9px; border-radius:50%; animation:blink 1.1s ease-in-out infinite alternate; }
.dot1 { background:var(--accent); animation-delay:0s; }
.dot2 { background:#fff;          animation-delay:.35s; }
.dot3 { background:var(--pglow);  animation-delay:.7s; }
@keyframes blink { from{opacity:.15;box-shadow:0 0 3px currentColor} to{opacity:1;box-shadow:0 0 10px currentColor} }
.dom-lbl { font-size:12px; color:var(--grey); margin:0 4px; }
.dom-code { font-family:'Playfair Display',serif; font-size:24px; font-weight:900; color:var(--pglow); letter-spacing:3px; }

/* ===== MAIL ===== */
.mail-addr {
