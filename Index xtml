function setLang(l) {
  lang = l;
  document.querySelectorAll('.lang-btn').forEach(b => {
    if (b.id && b.id.startsWith('lru')) b.classList.toggle('active', l==='ru');
    if (b.id && b.id.startsWith('luz')) b.classList.toggle('active', l==='uz');
  });
  const t = TR[l];
  for (const [k,v] of Object.entries(t)) {
    const el = document.getElementById(k);
    if (el) el.textContent = v;
  }
}
