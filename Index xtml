<script>
// ===== NAV =====
let current = null;
function goTo(id) {
  document.getElementById('home').classList.add('pushed');
  const el = document.getElementById(id);
  el.classList.add('active');
  el.scrollTop = 0;
  current = id;
}
function goBack() {
  if (!current) return;
  document.getElementById(current).classList.remove('active');
  document.getElementById('home').classList.remove('pushed');
  current = null;
}

// ===== MAIL APP LINKS (device-aware) =====
(function setMailLinks() {
  const email = 'kopitsentr.omad@bk.ru';
  const ua    = navigator.userAgent || '';
  const isIOS = /iPhone|iPad|iPod/.test(ua);
  const isAnd = /Android/.test(ua);

  // --- Mail.ru ---
  const mailruBtn = document.getElementById('mailru-btn');
  if (isIOS) {
    mailruBtn.addEventListener('click', function(e) {
      e.preventDefault();
      // Correct Mail.ru iOS deep link scheme
      var deepLink = 'mailru://compose?to=' + email;
      var appStore = 'https://apps.apple.com/app/id511310430';
      // Try to open app; if not installed, go to App Store
      var iframe = document.createElement('iframe');
      iframe.style.display = 'none';
      document.body.appendChild(iframe);
      iframe.src = deepLink;
      setTimeout(function() {
        document.body.removeChild(iframe);
        // If still on page → app not installed → open App Store
        window.location.href = appStore;
      }, 1200);
    });
  } else if (isAnd) {
    mailruBtn.addEventListener('click', function(e) {
      e.preventDefault();
      window.location.href = 'mailru://compose?to=' + email;
      setTimeout(function() {
        window.location.href = 'https://play.google.com/store/apps/details?id=ru.mail.mailapp';
      }, 800);
    });
  } else {
    mailruBtn.href   = 'https://e.mail.ru/compose/?to=' + email;
    mailruBtn.target = '_blank';
  }

  // --- Gmail ---
  const gmailBtn = document.getElementById('gmail-btn');
  if (isIOS) {
    gmailBtn.addEventListener('click', function(e) {
      e.preventDefault();
      window.location.href = 'googlegmail://co?to=' + email;
      setTimeout(function() {
        window.location.href = 'https://apps.apple.com/app/id422689480';
      }, 700);
    });
  } else if (isAnd) {
    gmailBtn.href = 'intent://compose?to=' + email + '#Intent;scheme=mailto;package=com.google.android.gm;end';
  } else {
    gmailBtn.href   = 'https://mail.google.com/mail/?view=cm&fs=1&to=' + email;
    gmailBtn.target = '_blank';
  }
})();

